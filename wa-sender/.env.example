# ── Supabase (service role — SOLO en la box, nunca en el navegador) ──
SUPABASE_URL=https://wnujoyzdpdyxblgdtxjw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Bridge WhatsApp de Ketzal ──
# Token compartido entre bridge y poller (genera uno: openssl rand -hex 32).
KETZAL_WA_TOKEN=
# Puerto loopback del bridge (distinto del 3100 de Gorilla).
KETZAL_WA_PORT=3101
# URL del bridge para el poller (misma box → loopback).
KETZAL_WA_URL=http://127.0.0.1:3101
# Carpeta de la sesión Baileys (disco persistente; perderla = re-parear QR).
KETZAL_WA_AUTH_DIR=/opt/ketzal-wa-session/baileys-state
# Nivel de log de Baileys (silent|error|warn|info|debug).
KETZAL_WA_LOG_LEVEL=warn
